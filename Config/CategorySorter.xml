<?xml version="1.0" encoding="UTF-8" ?>
<CategorySorter.Config>
    <!-- Additional log output. -->
    <VerboseLogging>false</VerboseLogging>

    <!-- Search radius in blocks around the sorting chest. -1 = full 3x3 chunks. -->
    <MaxDistance>20.0</MaxDistance>

    <!-- Name of the sorting chest (brackets optional, case-insensitive). -->
    <SortTag>[sort]</SortTag>

    <!-- Name of the optional catch-all chest for items with no matching category. -->
    <MiscTag>[misc]</MiscTag>

    <!--
        Optional aliases for freely chosen custom names.
        Short labels like [Food], [Weapons], [Tools], [Ammo] already work WITHOUT an entry,
        because compound categories (e.g. "Food/Cooking") also match their slash segments.
        You only need aliases for your own names that do NOT appear in the category name.
        "group" may bundle several real categories, separated by commas.
    -->
    <Aliases>
        <!-- <Alias label="Guns"   group="Ranged Weapons"/> -->
        <!-- <Alias label="Loot"   group="Special Items"/> -->
        <!-- <Alias label="Combat" group="Ranged Weapons,Melee Weapons,Ammo"/> -->
    </Aliases>
</CategorySorter.Config>

<?xml version="1.0" encoding="UTF-8" ?>
<CategorySorter.Config>
    <!-- Zusaetzliche Log-Ausgaben. -->
    <VerboseLogging>false</VerboseLogging>

    <!-- Suchradius in Bloecken um die Sortierkiste. -1 = volle 3x3 Chunks. -->
    <MaxDistance>20.0</MaxDistance>

    <!-- Name der Sortierkiste (Klammern optional, Gross/Klein egal). -->
    <SortTag>[sort]</SortTag>

    <!-- Name der optionalen Sammelkiste fuer nicht zuordenbare Items. -->
    <MiscTag>[misc]</MiscTag>

    <!--
        Optionale Aliase fuer frei waehlbare Wunschnamen.
        Kurze Labels wie [Food], [Weapons], [Tools], [Ammo] funktionieren bereits OHNE Eintrag,
        weil zusammengesetzte Kategorien (z. B. "Food/Cooking") auch auf ihre Slash-Segmente
        matchen. Aliase brauchst du nur fuer eigene Namen, die NICHT im Kategorienamen vorkommen.
        "group" darf mehrere echte Kategorien per Komma buendeln.
    -->
    <Aliases>
        <!-- <Alias label="Guns"   group="Ranged Weapons"/> -->
        <!-- <Alias label="Loot"   group="Special Items"/> -->
        <!-- <Alias label="Combat" group="Ranged Weapons,Melee Weapons,Ammo"/> -->
    </Aliases>
</CategorySorter.Config>
